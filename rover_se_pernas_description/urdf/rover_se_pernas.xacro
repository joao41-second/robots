    <origin xyz="0.4882383881861825 0.14983639102105517 1.1930603195605387" rpy="0 0 0"/>
    <mass value="46.37689397650178"/>
    <inertia ixx="2.002069" iyy="3.88283" izz="4.845997" ixy="0.001994" iyz="-0.000599" ixz="0.602482"/>
  </inertial>
  <visual>
