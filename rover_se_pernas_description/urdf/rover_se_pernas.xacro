<joint name="Revolucionar 16" type="continuous">
  <origin xyz="0.063206 0.118153 -0.225" rpy="0 0 0"/>
  <parent link="body_three_1"/>
  <child link="body_four_2"/>
  <axis xyz="0.471778 0.881717 -0.0"/>
</joint>

<joint name="Rígido 20" type="fixed">
  <origin xyz="0.360009 0.49 1.192273" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="body_five_v7_1"/>
</joint>

<joint name="Revolucionar 21" type="continuous">
