<?xml version="1.0" ?>
<robot name="rover_se_pernas" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find rover_se_pernas_description)/urdf/materials.xacro" />
<xacro:include filename="$(find rover_se_pernas_description)/urdf/rover_se_pernas.ros2control" />
<xacro:include filename="$(find rover_se_pernas_description)/urdf/rover_se_pernas.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="0.4882383881861825 0.14983639102105517 1.1930603195605387" rpy="0 0 0"/>
    <mass value="46.37689397650178"/>
    <inertia ixx="2.002069" iyy="3.88283" izz="4.845997" ixy="0.001994" iyz="-0.000599" ixz="0.602482"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find rover_se_pernas_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find rover_se_pernas_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

